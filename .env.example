# VibeBridge Environment Variables
# Copy this file to .env and fill in your real values.
# DO NOT commit .env to git.

# =========================
# Feishu App Credentials
# Get these from https://open.feishu.cn/app
# =========================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# Connection mode: websocket | webhook
FEISHU_MODE=websocket

# =========================
# Provider Defaults
# =========================
# VB_DEFAULT_PROVIDER=opencode
