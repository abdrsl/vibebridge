# =========================
# App
# =========================
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# =========================
# LLM API Keys
# 填真实值到 .env，不要提交到 git
# =========================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# OpenRouter / 其他聚合平台（可选）
OPENROUTER_API_KEY=

# =========================
# LiteLLM
# 如果后面启用 LiteLLM gateway，可填写本地地址
# 例如: http://127.0.0.1:4000
# =========================
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=

# =========================
# Feishu
# webhook 机器人地址
# =========================
FEISHU_BOT_WEBHOOK=
FEISHU_BOT_SECRET=

# Feishu App 模式（后面若升级为事件订阅机器人再用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# =========================
# Database
# Docker 内部连接可用 postgres/redis/qdrant 作为主机名
# 若从宿主机直连，通常用 127.0.0.1
# =========================
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ai_product
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_API_KEY=

# =========================
# Playwright
# =========================
PLAYWRIGHT_BROWSERS_PATH=0

# =========================
# Security / Optional
# =========================
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
