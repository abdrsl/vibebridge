# Logrotate configuration for OpenCode-Feishu Bridge
/home/user/workspace/vibebridge/logs/*.log {
    daily
    missingok
    rotate 7
    compress
    delaycompress
    notifempty
    create 0640 akliedrak akliedrak
    copytruncate
    dateext
    dateformat -%Y%m%d
}

# Exclude pid files and other non-log files
/home/user/workspace/vibebridge/logs/*.pid {
    missingok
    rotate 0
    weekly
    create 0640 akliedrak akliedrak
}