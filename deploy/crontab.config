# AI Project Lab 自动启动配置
# 添加到crontab: crontab -e
# 然后添加以下行:

# 每分钟检查服务器状态，如果停止则自动重启
# 使用flock防止重复运行
* * * * * cd /home/user/workspace/vibebridge && flock -n /tmp/vibebridge-autostart.lock -c './auto_recovery.sh start' >> /home/user/workspace/vibebridge/logs/cron.log 2>&1

# 每5分钟检查隧道状态，如果不可用则自动切换
*/5 * * * * cd /home/user/workspace/vibebridge && flock -n /tmp/vibebridge-tunnel.lock -c './auto_recovery.sh tunnel' >> /home/user/workspace/vibebridge/logs/cron.log 2>&1

# 清理：如果需要停止自动监控，注释掉或删除上面的行