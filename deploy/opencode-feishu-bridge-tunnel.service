[Unit]
Description=AI Project Lab Tunnel (Auto-switching)
After=opencode-feishu-bridge.service
Requires=opencode-feishu-bridge.service

[Service]
Type=simple
User=akliedrak
WorkingDirectory=/home/user/workspace/opencode-feishu-bridge
Environment=PATH=/home/user/.nvm/versions/node/v24.14.0/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/user/workspace/opencode-feishu-bridge/auto_recovery.sh daemon
Restart=always
RestartSec=30
StandardOutput=append:/home/user/workspace/opencode-feishu-bridge/logs/tunnel.log
StandardError=append:/home/user/workspace/opencode-feishu-bridge/logs/tunnel.log

[Install]
WantedBy=multi-user.target